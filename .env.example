# Open Research Platform — Environment Variables
# Copy to .env and fill in values. Never commit .env to the repository.

# Override source mode detection (ci_checkout, local_dev, manual_snapshot)
# ORP_SOURCE_MODE=local_dev

# Number of CPU cores to allocate to jobs
# ORP_CORES_USED=4

# Container image digest (set automatically in CI; override for local container runs)
# ORP_IMAGE_DIGEST=sha256:...
